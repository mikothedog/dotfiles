{
    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip-format": "{:%e %B %Y}",
        "on-click": "~/.local/bin/waybar-calendar"
    },
    "clock#date": {
        "interval": 10,
        "format": "{:%e %b %Y}",
        "tooltip-format": "{:%e %B %Y}"
    },
    "custom/spacer": {
        "format": " ",
        "tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 14
    }
}
