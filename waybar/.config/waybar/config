{
    "layer": "top",
    "position": "top",
    "height": 30,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "memory",
        "cpu",
        "network",
        "tray",
        "custom/spacer",
        "clock#time"
    ],


    // -------------------------------------------------------------------------
    // Modules
    // -------------------------------------------------------------------------

    "clock#time": {
        "interval": 1,
        "format": "{:%H:%M}",
        "tooltip-format": "{:%e %B %Y}",
        "on-click": "zen-browser https://calendar.google.com"
    },

    "clock#date": {
      "interval": 10,
      "format": "{:%e %b %Y}",
      "tooltip-format": "{:%e %B %Y}"
    },

    "cpu": {
        "interval": 5,
        "format": "{usage}%  ", // removed "({load})" after usage
        "states": {
          "warning": 70,
          "critical": 90
        }
    },

    "hyprland/language": {
        "format": "{}  ",
        "format-en": "EN",
        "format-he": "HE",
        "keyboard-name": "telink-wireless-gaming-keyboard"
    },

    "memory": {
        "interval": 5,
        "format": "{}% ",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 5,
        "format-wifi": "{signalStrength}% 󰖩", //   
        "format-ethernet": "  {ifname}: {ipaddr}/{cidr}",
        "format-disconnected": "⚠  Disconnected",
        "tooltip-format": "{essid}: {ipaddr}",
        "on-click": "ghostty -e impala"
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 120
    },

    "hyprland/workspaces": {
        "all-outputs": false,
        "disable-scroll": true,
        "on-click": "activate",
        "format": "{name}",
        "format-icons": {
            "1:www": "龜",
            "2:mail": " ",
            "3:editor": " ",
            "4:terminals": " ",
            "5:portal": " ",
            "urgent": " ",
            "focused": " ",
            "default": " "
        }
    },

    "custom/spacer": {
        "format": " ",
        "tooltip": false
    },

    "tray": {
        "icon-size": 21,
        "spacing": 14
    }

}
